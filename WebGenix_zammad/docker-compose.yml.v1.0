networks:
  zammad-net:
    driver: bridge

volumes:
  zammad-elasticsearch-data:
  zammad-postgresql-data:
  zammad-redis-data:
  zammad-storage:
  zammad-backup:

x-zammad-service: &zammad-service
  image: ghcr.io/zammad/zammad:7.0.0-1
  restart: always
  networks:
    - zammad-net
  environment: &zammad-environment
    MEMCACHE_SERVERS: zammad-memcached:11211
    POSTGRESQL_DB: zammad_production
    POSTGRESQL_HOST: zammad-postgresql
    POSTGRESQL_USER: zammad
    POSTGRESQL_PASS: zammad_secret
    POSTGRESQL_PORT: "5432"
    POSTGRESQL_OPTIONS: "?pool=50"
    REDIS_URL: redis://zammad-redis:6379
    ELASTICSEARCH_ENABLED: "true"
    ELASTICSEARCH_HOST: zammad-elasticsearch
    ELASTICSEARCH_PORT: "9200"
    ELASTICSEARCH_SCHEMA: http
    ELASTICSEARCH_NAMESPACE: zammad
    ELASTICSEARCH_REINDEX: "false"
    BACKUP_DIR: /var/tmp/zammad
    BACKUP_TIME: "03:00"
    HOLD_DAYS: "10"
    TZ: Asia/Kolkata
  volumes:
    - zammad-backup:/var/tmp/zammad:ro
    - zammad-storage:/opt/zammad/storage
  depends_on:
    - zammad-memcached
    - zammad-postgresql
    - zammad-redis

services:

  # ── Memcached ──
  zammad-memcached:
    image: memcached:1.6.40-alpine
    container_name: zammad-memcached
    restart: always
    networks:
      - zammad-net
    command: memcached -m 256M

  # ── PostgreSQL (kept at v15 to match existing volume data) ──
  zammad-postgresql:
    image: postgres:15-alpine
    container_name: zammad-postgresql
    restart: always
    networks:
      - zammad-net
    environment:
      POSTGRES_DB: zammad_production
      POSTGRES_USER: zammad
      POSTGRES_PASSWORD: zammad_secret
    volumes:
      - zammad-postgresql-data:/var/lib/postgresql/data

  # ── Redis ──
  zammad-redis:
    image: redis:7-alpine
    container_name: zammad-redis
    restart: always
    networks:
      - zammad-net
    volumes:
      - zammad-redis-data:/data

  # ── Elasticsearch ──
  zammad-elasticsearch:
    image: elasticsearch:8.13.4
    container_name: zammad-elasticsearch
    restart: always
    networks:
      - zammad-net
    environment:
      discovery.type: single-node
      xpack.security.enabled: "false"
      ES_JAVA_OPTS: -Xms512m -Xmx512m
    volumes:
      - zammad-elasticsearch-data:/usr/share/elasticsearch/data

  # ── Init (runs once then exits with code 0) ──
  zammad-init:
    <<: *zammad-service
    container_name: zammad-init
    command: ["zammad-init"]
    restart: on-failure
    user: "0:0"
    environment:
      <<: *zammad-environment
      POSTGRESQL_DB_CREATE: "true"
    volumes:
      - zammad-backup:/var/tmp/zammad
      - zammad-storage:/opt/zammad/storage
    depends_on:
      - zammad-memcached
      - zammad-postgresql
      - zammad-redis
      - zammad-elasticsearch

  # ── Rails Server ──
  zammad-railsserver:
    <<: *zammad-service
    container_name: zammad-railsserver
    command: ["zammad-railsserver"]
    environment:
      <<: *zammad-environment
      OPENID_CONNECT_HTTP_VERIFY_NONE: "true"
      OPENID_CONNECT_SSL_VERIFY_PEER: "false"
      RUBY_SSL_VERIFY_NONE: "true"
      SSL_CERT_FILE: "/etc/ssl/certs/ca-certificates.crt"
      OPENID_CONNECT_CLIENT_ID: "zammad"
      OPENID_CONNECT_CLIENT_SECRET: "m91Dw00jpIdgnaw8CHhznbgRGIZMASGt"
      NODE_TLS_REJECT_UNAUTHORIZED: "0"
    depends_on:
      - zammad-memcached
      - zammad-postgresql
      - zammad-redis

  # ── Scheduler ──
  zammad-scheduler:
    <<: *zammad-service
    container_name: zammad-scheduler
    command: ["zammad-scheduler"]

  # ── Websocket ──
  zammad-websocket:
    <<: *zammad-service
    container_name: zammad-websocket
    command: ["zammad-websocket"]

  # ── Nginx (port 8090 → no conflict with Keycloak on 8080) ──
  zammad-nginx:
    <<: *zammad-service
    container_name: zammad-nginx
    command: ["zammad-nginx"]
    ports:
      - "8090:8080"
    depends_on:
      - zammad-railsserver
      - zammad-memcached
      - zammad-postgresql
      - zammad-redis

  # ── Backup ──
  zammad-backup:
    <<: *zammad-service
    container_name: zammad-backup
    command: ["zammad-backup"]
    user: "0:0"
    volumes:
      - zammad-backup:/var/tmp/zammad
      - zammad-storage:/opt/zammad/storage
